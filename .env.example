# --- App ---
NODE_ENV=development

# --- PostgreSQL ---
POSTGRES_USER=egresados
POSTGRES_PASSWORD=egresados_dev
POSTGRES_DB=egresados
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://egresados:egresados_dev@localhost:5432/egresados?schema=public

# --- Redis / BullMQ ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# --- API (NestJS + tRPC) ---
API_HOST=0.0.0.0
API_PORT=3001
# IMPORTANTE: Cambiar por un secreto aleatorio en producción (mínimo 64 chars)
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# --- Worker ---
WORKER_CONCURRENCY=5

# --- Web (Next.js) ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Tras la primera migración, crear usuario demo (admin@example.com / password):
#   npm run prisma:seed -w @egresados/api

# --- Email (Nodemailer) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Egresados <no-reply@example.com>"

# --- Storage (CVs, logos, exports) ---
# Opción A: almacenamiento local (por defecto)
PUBLIC_ASSETS_BASE_URL=http://localhost:4000/static

# Opción B: AWS S3 (descomentar para usar S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=egresados-storage
# AWS_REGION=us-east-1
